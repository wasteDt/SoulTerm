{
  "name": "soulterm",
  "version": "1.0.0",
  "description": "Electron desktop terminal app that opens a terminal window on startup.",
  "main": "main.js",
  "bin": {
    "soulterm": "./bin/soulterm.js"
  },
  "scripts": {
    "postinstall": "node ./scripts/postinstall.js",
    "start": "pnpm run build:renderer && node ./bin/soulterm.js",
    "build:renderer": "vite build",
    "fix:electron": "node ./scripts/postinstall.js --force"
  },
  "keywords": [
    "electron",
    "terminal",
    "xterm",
    "node-pty"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron": "^31.7.7",
    "node-pty": "^1.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.2"
  }
}
